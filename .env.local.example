# ============================================================
# RSI Alert Pro — 환경변수 설정 예시
# 이 파일을 복사하여 .env.local로 저장 후 값을 입력하세요
# ============================================================

# Alpha Vantage (미국주식 분봉 데이터)
ALPHA_VANTAGE_KEY=your_alpha_vantage_api_key

# 텔레그램 봇 알림
TELEGRAM_BOT_TOKEN=1234567890:ABCdefGHIjklMNOpqrSTUvwxYZ
TELEGRAM_CHAT_ID=-100123456789

# 이메일 알림 (Resend)
RESEND_API_KEY=re_your_resend_api_key
ALERT_EMAIL=you@example.com

# 한국투자증권 KIS OpenAPI
KIS_APP_KEY=your_kis_app_key
KIS_APP_SECRET=your_kis_app_secret

# Vercel KV (Redis) - Vercel 프로젝트에서 자동 설정
KV_REST_API_URL=https://your-kv.kv.vercel-storage.com
KV_REST_API_TOKEN=your_kv_token

# Web Push VAPID 키 (npx web-push generate-vapid-keys 로 생성)
NEXT_PUBLIC_VAPID_PUBLIC_KEY=your_vapid_public_key
VAPID_PRIVATE_KEY=your_vapid_private_key
VAPID_EMAIL=mailto:admin@example.com

# Cron 보안 (임의 문자열)
CRON_SECRET=your_random_secret_string
